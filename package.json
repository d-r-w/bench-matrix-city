{
  "name": "bench-matrix-city",
  "module": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "build": "bun build --target=bun src/server.ts --outdir dist",
    "check": "bunx --bun @biomejs/biome check --write ./src && bunx --bun tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/bun": "^1.3.14",
    "@types/three": "0.160.0",
    "typescript": "^5.4.0"
  }
}
